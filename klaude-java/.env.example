# Klaude Java 环境配置模板
# 复制为 .env 后按本机环境修改；不要提交真实 API Key

# Java runtime；启动器会在 JVM 启动前读取
KLAUDE_JAVA_HOME=E:/Java/jdk-21

# Anthropic 或兼容 Anthropic Messages API 的第三方服务
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
KLAUDE_LLM_DEFAULT_MODEL=claude-sonnet-4-6

# Core daemon
KLAUDE_HOST=127.0.0.1
KLAUDE_PORT=7437

# Logging
KLAUDE_LOG_LEVEL=INFO
KLAUDE_LOG_FILE=~/.klaude/logs/core.log
KLAUDE_LOG_FORMAT=text

# Agent
KLAUDE_MAX_STEPS=20

# Trace
KLAUDE_TRACE_ENABLED=true
KLAUDE_TRACE_FILE=~/.klaude/traces/daemon.jsonl
KLAUDE_TRACE_INCLUDE_LLM_PAYLOAD=false

# Permission
KLAUDE_PERMISSION_TIMEOUT_S=60

# Conversation compaction
KLAUDE_COMPACT_THRESHOLD=0
KLAUDE_COMPACT_TOOL_LIMIT=8000
KLAUDE_COMPACT_TOOL_KEEP=4000
